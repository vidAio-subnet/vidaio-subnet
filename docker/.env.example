# SN85 (Vidaio) Miner Environment Configuration
# Copy this file to .env and customize with your values

# ==============================================================================
# REQUIRED: Bittensor Wallet Configuration
# ==============================================================================

# Wallet name and hotkey from `btcli wallet list`
WALLET_NAME=default
WALLET_HOTKEY=default

# Path to your bittensor wallets directory
WALLET_PATH=~/.bittensor/wallets

# ==============================================================================
# REQUIRED: Bittensor Network Configuration
# ==============================================================================

BT_NETWORK=finney       # finney (mainnet) or test
BT_NETUID=85            # Subnet 85 for Vidaio
BT_AXON_PORT=8091       # External port for miner axon

# ==============================================================================
# REQUIRED: S3-Compatible Storage (Backblaze/Cloudflare/AWS)
# ==============================================================================

# Storage provider type: backblaze, amazon_s3, cloudflare, or hippius
BUCKET_TYPE=backblaze

# Your S3 bucket name
BUCKET_NAME=your-bucket-name

# S3 endpoint URL (e.g., s3.us-west-000.backblazeb2.com)
BUCKET_COMPATIBLE_ENDPOINT=s3.us-west-000.backblazeb2.com

# S3 credentials
BUCKET_COMPATIBLE_ACCESS_KEY=your-access-key
BUCKET_COMPATIBLE_SECRET_KEY=your-secret-key

# ==============================================================================
# OPTIONAL: Chutes Remote Inference
# ==============================================================================

# Enable Chutes for scene classification (recommended for CPU-only setups)
USE_CHUTES=false

# Your Chutes API key (get from https://chutes.ai)
CHUTES_API_KEY=sk_xxx

# Chute endpoint for scene classification
CHUTES_SCENE_CHUTE_ID=scene-classifier-v1
CHUTES_TIMEOUT=30
CHUTES_MAX_RETRIES=2

# ==============================================================================
# OPTIONAL: Paths and Resource Limits
# ==============================================================================

# Local paths for data storage
TEMP_PATH=./data/temp
OUTPUT_PATH=./data/output
LOG_PATH=./data/logs
MODEL_PATH=./models

# Maximum video length in seconds
MAX_VIDEO_LENGTH=300

# ==============================================================================
# OPTIONAL: Monitoring and Logging
# ==============================================================================

# Weights & Biases API key (for analytics)
WANDB_API_KEY=

# Watchtower notifications (slack webhook for container updates)
WATCHTOWER_NOTIFICATIONS=slack
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
