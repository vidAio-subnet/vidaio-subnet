COMPOSE_PROJECT_NAME=miner
MINER_SHARED_DIR=/tmp/vidaio-miner-video-tmp

# Per-container processing limits. Each service accepts MAX_CONCURRENT_* active
# jobs plus MAX_QUEUE_SIZE_* waiting jobs before returning HTTP 429.
MAX_CONCURRENT_UPSCALING=2
MAX_QUEUE_SIZE_UPSCALING=5
MAX_CONCURRENT_COMPRESSION=2
MAX_QUEUE_SIZE_COMPRESSION=5

# Processing backend. Use "http" for local Docker services and "modal" for
# Modal SDK calls to the deployed workers in miner/modal_workers.py.
MINER_PROCESSING_BACKEND=http
MODAL_APP_NAME=vidaio-miner-workers
MINER_MODAL_UPSCALING_FUNCTION=upscale_video2x
MINER_MODAL_COMPRESSION_FUNCTION=compress

# Modal authentication for neurons/miner.py and the Modal CLI.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_MINER_SECRET_NAME=vidaio-miner-secrets
MODAL_GPU=RTX-PRO-6000
MODAL_SHORT_COMPRESSION_GPU=L4
MODAL_LONG_COMPRESSION_GPU=RTX-PRO-6000
MODAL_CPU_CORES=16
MODAL_UPSCALING_MAX_CONTAINERS=5
MODAL_COMPRESSION_MAX_CONTAINERS=5
MODAL_BUFFER_CONTAINERS=0
MODAL_SCALEDOWN_WINDOW_SECONDS=300
MODAL_UPSCALING_TIMEOUT_SECONDS=1800
MODAL_COMPRESSION_TIMEOUT_SECONDS=14400
MODAL_COMPRESSION_PROBE_TIMEOUT_SECONDS=60
MODAL_LONG_COMPRESSION_THRESHOLD_SECONDS=1200
MODAL_LONG_COMPRESSION_CHUNK_SECONDS=600
MODAL_LONG_COMPRESSION_CHUNK_PARALLELISM=4
MODAL_CLEANUP_PERIOD_HOURS=1
MODAL_VOLUME_FILE_TTL_SECONDS=

# Local temp-file cleanup for MINER_SHARED_DIR / SHARED_VOLUME_PATH. The TTL
# defaults to presigned URL expiry + grace when MINER_TEMP_FILE_TTL_SECONDS is blank.
MINER_CLEANUP_ENABLED=true
MINER_CLEANUP_INTERVAL_SECONDS=300
MINER_CLEANUP_MAX_VOLUME_BYTES=9000000000
MINER_CLEANUP_MIN_FILE_AGE_SECONDS=60
MINER_TEMP_FILE_TTL_SECONDS=
PRESIGNED_URL_CLEANUP_GRACE_SECONDS=600

# S3-compatible object cleanup for miner-owned outputs under the configured
# prefixes. The TTL defaults to presigned URL expiry + grace when blank.
MINER_STORAGE_CLEANUP_ENABLED=true
MINER_STORAGE_CLEANUP_PREFIXES=processing/,upscaling/
MINER_STORAGE_OBJECT_TTL_SECONDS=

# Long-video compression chunking. The default cuts at source keyframes around
# 10-minute boundaries for videos >= 20 minutes, compresses chunks in parallel,
# and concat-merges the encoded chunks with stream copy.
COMPRESSION_CHUNKING_ENABLED=true
COMPRESSION_CHUNK_MIN_DURATION_SECONDS=1200
COMPRESSION_CHUNK_TARGET_SECONDS=600
COMPRESSION_CHUNK_PARALLELISM=2

# S3-compatible storage settings
MINER_STORAGE_PROVIDER=backblaze
MINER_STORAGE_S3_ACCESS_KEY_ID=your-access-key
MINER_STORAGE_S3_SECRET_ACCESS_KEY=your-secret-key
MINER_STORAGE_S3_REGION=us-east-005
MINER_STORAGE_S3_BUCKET_NAME=your-bucket-name
MINER_STORAGE_S3_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com

# For AWS S3, keep the same variable names and leave the endpoint blank.
# MINER_STORAGE_S3_REGION=us-west-1
# MINER_STORAGE_S3_BUCKET_NAME=vidaiosubnet
# MINER_STORAGE_S3_ENDPOINT_URL=
