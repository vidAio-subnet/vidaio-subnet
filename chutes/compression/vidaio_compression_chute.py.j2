## ============ VARIABLES =======================
HF_REPO_NAME = "{{ huggingface_repository_name }}"
HF_REPO_REVISION = "{{ huggingface_repository_revision }}"
CHUTES_USERNAME = "{{ chute_username }}"
CHUTE_NAME = "{{ chute_name }}"
FILENAME = "miner.py"
CLASSNAME = "Miner"
CHUTE_CONFIG_FILENAME = "chute_config.yml"


## ========= DATA CLASSES ================
class CompressionInput(BaseModel):
    video_url: str
    vmaf_threshold: float
    target_codec: str
    codec_mode: str
    target_bitrate: float
    upload_url: str = ""


class ProcessOutput(BaseModel):
    success: bool
    output_url: str | None = None
    output_video_b64: str | None = None
    error: str | None = None


## ========= UTILITY FUNCTIONS =================
def get_whitelisted_paths() -> set[Path]:
    STDLIB_ROOT = Path(get_paths()["stdlib"]).resolve()
    SITE_PACKAGES_ROOTS = {Path(p).resolve() for p in getsitepackages()}
    SITE_PACKAGES_ROOTS.add(Path(getusersitepackages()).resolve())
    return {STDLIB_ROOT, *SITE_PACKAGES_ROOTS}


def post_check_files_against_whitelist(*, before: set[str], miner_path: Path) -> None:
    miner_path = miner_path.resolve()
    WHITELIST = get_whitelisted_paths()
    after = set(sys.modules.keys()) - before
    offenders = []
    for module_loaded_name in sorted(after):
        module_loaded = sys.modules.get(module_loaded_name)
        if module_loaded is None:
            continue
        module_loaded_file = getattr(module_loaded, "__file__", None)
        if not module_loaded_file:
            continue
        module_loaded_filepath = Path(module_loaded_file).resolve()
        if module_loaded_filepath == miner_path:
            continue
        if any(module_loaded_filepath.is_relative_to(root) for root in WHITELIST):
            continue
        offenders.append(module_loaded_name)
    if offenders:
        raise ImportError(
            f"Miner loaded modules outside the whitelist: {', '.join(offenders)}"
        )


class DuplicatePreservingLoader(yaml.SafeLoader):
    pass

def construct_mapping(loader, node, deep=False):
    loader.flatten_mapping(node)
    
    # Check for duplicates
    keys = set()
    has_duplicate = False
    for key_node, value_node in node.value:
        key = loader.construct_object(key_node, deep=deep)
        if key in keys:
            has_duplicate = True
            break
        keys.add(key)
        
    if has_duplicate:
        mapping = []
        for key_node, value_node in node.value:
            key = loader.construct_object(key_node, deep=deep)
            value = loader.construct_object(value_node, deep=deep)
            mapping.append({key: value})
        return mapping
    else:
        mapping = {}
        for key_node, value_node in node.value:
            key = loader.construct_object(key_node, deep=deep)
            value = loader.construct_object(value_node, deep=deep)
            mapping[key] = value
        return mapping

DuplicatePreservingLoader.add_constructor(
    yaml.resolver.BaseResolver.DEFAULT_MAPPING_TAG,
    construct_mapping)

def load_chute_config_from_hf_repo(config_path: Path) -> dict:
    try:
        if not config_path.exists():
            raise ValueError("No config file found in repo")
        with config_path.open() as f:
            config = yaml.load(f, Loader=DuplicatePreservingLoader)
            print("Loaded Chutes Configuration")
            return config or {}
    except Exception as e:
        print(f"Failed to load Chutes Configuration, using defaults: {e}")
        return {}


def safe_instantiate(cls, config: dict | list):
    params = {}
    methods_to_call = []
    
    if isinstance(config, dict):
        for k, v in config.items():
            if k in signature(cls).parameters:
                params[k] = v
            else:
                methods_to_call.append((k, v))
    elif isinstance(config, list):
        for item in config:
            if isinstance(item, dict):
                for k, v in item.items():
                    if k in signature(cls).parameters:
                        params[k] = v
                    else:
                        methods_to_call.append((k, v))
                        
    obj = cls(**params)
    for function_name, value in methods_to_call:
        if not hasattr(obj, function_name) or not callable(getattr(obj, function_name)):
            continue
        method = getattr(obj, function_name)
        if isinstance(value, list):
            for v in value:
                if isinstance(v, (tuple, list)):
                    method(*v)
                else:
                    method(v)
        else:
            method(value)
    return obj


def load_chute(
    hf_repo: str,
    hf_revision: str,
    config_filename: str,
    chutes_username: str,
    chute_name: str,
) -> Chute:
    # Try local config first (for local builds), fall back to HF download
    local_config = Path(__file__).resolve().parent / config_filename
    if local_config.exists():
        hf_repo_path = local_config.parent
    else:
        hf_repo_path = Path(snapshot_download(hf_repo, revision=hf_revision))
    config = load_chute_config_from_hf_repo(config_path=hf_repo_path / config_filename)
    print(f"config:\n{config}")

    image_config = config.get("Image", {})
    image_defaults = {
        "username": chutes_username,
        "name": chute_name,
        "tag": "latest",
        "readme": "README.md",
    }
    if isinstance(image_config, dict):
        image_config.update(image_defaults)
    elif isinstance(image_config, list):
        image_config.append(image_defaults)
        
    chute_image = safe_instantiate(cls=Image, config=image_config)

    machine_specs = safe_instantiate(cls=NodeSelector, config=config.get("NodeSelector", {}))

    chute_config = config.get("Chute", {})
    chute_defaults = {
        "username": chutes_username,
        "name": chute_name,
        "image": chute_image,
        "node_selector": machine_specs,
        "allow_external_egress": False,
        "readme": "README.md",
    }
    if isinstance(chute_config, dict):
        chute_config.update(chute_defaults)
    elif isinstance(chute_config, list):
        chute_config.append(chute_defaults)
        
    chute = safe_instantiate(cls=Chute, config=chute_config)
    return chute


def load_miner_from_hf_repo(path_hf_repo: Path, filename: str, classname: str):
    path_hf_repo = path_hf_repo.resolve()
    path_miner = path_hf_repo / filename
    if not path_miner.is_file():
        raise FileNotFoundError(f"Required file '{filename}' not in repo {path_hf_repo}")

    WHITELIST = get_whitelisted_paths()

    class HFRepoImportBlocker(PathFinder):
        @classmethod
        def find_spec(cls, fullname, path=None, target=None):
            spec = super().find_spec(fullname, path, target)
            if spec is None or spec.origin is None:
                return spec
            origin_path = Path(spec.origin).resolve()
            if any(origin_path.is_relative_to(root) for root in WHITELIST):
                return spec
            raise ImportError(
                f"Import blocked: '{fullname}' (file: {origin_path}) is not in the whitelist. "
                f"All code related to the miner MUST be inside {filename}"
            )

    try:
        before_exec = set(sys.modules.keys())
        sys.meta_path.insert(0, HFRepoImportBlocker)
        spec = spec_from_file_location("miner", path_miner)
        module = module_from_spec(spec)
        sys.modules["miner"] = module
        spec.loader.exec_module(module)
        miner_object = getattr(module, classname)
        miner = miner_object(path_hf_repo)
        post_check_files_against_whitelist(before=before_exec, miner_path=path_miner)
    except Exception as e:
        raise e
    finally:
        sys.meta_path.remove(HFRepoImportBlocker)
    return miner


## ========= ENDPOINTS ================
chute = load_chute(
    hf_repo=HF_REPO_NAME,
    hf_revision=HF_REPO_REVISION,
    chutes_username=CHUTES_USERNAME,
    chute_name=CHUTE_NAME,
    config_filename=CHUTE_CONFIG_FILENAME,
)


@chute.on_startup()
async def load_model(self) -> None:
    self.miner = None
    try:
        if LOCAL_TEST:
            hf_repo_path = Path(__file__).resolve().parent
            print(f"LOCAL_TEST mode: loading miner from {hf_repo_path}")
        else:
            print(f"loading miner from {HF_REPO_NAME} with revision {HF_REPO_REVISION}")
            hf_repo_path = Path(snapshot_download(HF_REPO_NAME, revision=HF_REPO_REVISION))
            print(f"loaded miner from {HF_REPO_NAME} with revision {HF_REPO_REVISION}")
        self.miner = load_miner_from_hf_repo(
            path_hf_repo=hf_repo_path, filename=FILENAME, classname=CLASSNAME
        )
        print(f"Miner loaded: {self.miner}")
        self.status = "healthy"
    except Exception as e:
        self.status = f"Failed to load miner: {e}"
        print(self.status)


@chute.cord(public_api_path="/health")
async def health(self, *args, **kwargs) -> dict[str, Any]:
    return {
        "status": self.status,
        "miner": str(self.miner),
    }


@chute.cord(public_api_path="/process",
    input_schema=CompressionInput
)
async def process(self, data: CompressionInput) -> dict:
    import subprocess as _subprocess
    import traceback as _tb
    try:
        print(f"[chute] /process called: target_codec={data.target_codec}, codec_mode={data.codec_mode}, "
              f"vmaf_threshold={data.vmaf_threshold}, target_bitrate={data.target_bitrate}, "
              f"video_url={data.video_url[:120]}...")
        if self.miner is None:
            raise ValueError("Miner was not properly loaded!")

        # Download video -- direct in local test, via chutes proxy in production
        if LOCAL_TEST:
            download_url = data.video_url
        else:
            download_url = f"https://proxy.chutes.ai/misc/proxy?url={quote(data.video_url, safe='')}"
        print(f"[chute] Downloading video from: {download_url[:120]}...")
        async with ClientSession() as session:
            async with session.get(download_url) as response:
                response.raise_for_status()
                video_content = await response.read()
        print(f"[chute] Downloaded {len(video_content)} bytes")

        # Save to temp file and process
        with NamedTemporaryFile(prefix="vidaio_comp_", suffix=".mp4", delete=False) as f:
            f.write(video_content)
            input_path = Path(f.name)
        print(f"[chute] Saved input to {input_path}")

        try:
            print(f"[chute] Calling miner.process_video({input_path}, vmaf={data.vmaf_threshold}, "
                  f"codec={data.target_codec}, mode={data.codec_mode}, bitrate={data.target_bitrate})")
            output_path = self.miner.process_video(
                input_path,
                data.vmaf_threshold,
                data.target_codec,
                data.codec_mode,
                data.target_bitrate,
            )
            print(f"[chute] Miner returned output: {output_path}, exists={output_path.exists()}")

            with open(output_path, "rb") as f:
                video_bytes = f.read()
            print(f"[chute] Output video size: {len(video_bytes)} bytes")

            # Upload result -- try presigned URL, fall back to inline base64 in local test
            uploaded = False
            if data.upload_url:
                try:
                    if LOCAL_TEST:
                        upload_url = data.upload_url
                    else:
                        upload_url = f"https://proxy.chutes.ai/misc/proxy?url={quote(data.upload_url, safe='')}"
                    print(f"[chute] Uploading result to: {upload_url[:120]}...")
                    async with ClientSession() as session:
                        async with session.put(
                            upload_url,
                            data=video_bytes,
                            headers={"Content-Type": "application/octet-stream"},
                        ) as resp:
                            resp.raise_for_status()
                    uploaded = True
                    print("[chute] Upload succeeded")
                except Exception as upload_err:
                    if not LOCAL_TEST:
                        raise
                    print(f"[chute] Upload failed (local test), returning video inline: {upload_err}")

            if uploaded:
                result = ProcessOutput(success=True, output_url=data.upload_url)
            else:
                result = ProcessOutput(
                    success=True,
                    output_video_b64=base64.b64encode(video_bytes).decode(),
                )
                print(f"[chute] Returning inline base64 ({len(result.output_video_b64)} chars)")
        finally:
            # Cleanup temp files
            input_path.unlink(missing_ok=True)
            if 'output_path' in dir() and output_path.exists():
                output_path.unlink(missing_ok=True)

    except _subprocess.CalledProcessError as e:
        error_msg = (
            f"Error during compression: {e}\n"
            f"  stdout: {e.stdout}\n"
            f"  stderr: {e.stderr}"
        )
        print(f"[chute] SUBPROCESS ERROR:\n{error_msg}")
        _tb.print_exc()
        result = ProcessOutput(success=False, error=error_msg)
    except Exception as e:
        print(f"[chute] ERROR during compression: {e}")
        _tb.print_exc()
        result = ProcessOutput(success=False, error=f"Error during compression: {e}")

    print(f"[chute] Returning: success={result.success}, error={result.error}")
    return result.model_dump(mode="json")
